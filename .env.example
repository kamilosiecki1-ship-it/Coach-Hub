# Supabase PostgreSQL — Connection Pooling (used by Prisma Client at runtime)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase PostgreSQL — Direct connection (used by prisma migrate deploy)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-eu-west-1.pooler.supabase.com:5432/postgres"

# NextAuth
NEXTAUTH_SECRET=change-me-to-a-random-string-minimum-32-chars
NEXTAUTH_URL=http://localhost:3000

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=o4-mini

# Invite & password reset TTLs
INVITE_TTL_DAYS=7
RESET_TOKEN_TTL_MINUTES=60

# Email — Resend (https://resend.com — free plan: 3000 emails/month)
RESEND_API_KEY=re_...
EMAIL_FROM="Coach Hub <onboarding@resend.dev>"
